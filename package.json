{
    "name": "tg-downloader-bot",
    "version": "2.0.0",
    "description": "Production-grade Telegram video downloader bot",
    "scripts": {
        "dev": "APP_ENTRY=src bun src/index.ts",
        "dev:bot": "bun --watch src/bot/index.ts",
        "dev:worker": "bun --watch src/worker/index.ts",
        "bot": "bun src/bot/index.ts",
        "worker": "bun src/worker/index.ts",
        "build": "bun build src/index.ts src/bot/index.ts src/worker/index.ts --outdir dist --target bun",
        "start": "bun dist/index.js",
        "start:bot": "bun dist/bot/index.js",
        "start:worker": "bun dist/worker/index.js",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "telegraf": "^4.16.3",
        "bullmq": "^5.7.0",
        "ioredis": "^5.3.2",
        "winston": "^3.13.0"
    },
    "devDependencies": {
        "@types/node": "^20.12.7",
        "typescript": "^6.0.2"
    }
}
