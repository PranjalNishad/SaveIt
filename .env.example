# Required
BOT_TOKEN=your_telegram_bot_token


REDIS_URL=redis://127.0.0.1:6379

# Optional fallback if REDIS_URL is not set
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# sudo systemctl start redis - to start redis server
# redis-cli ping - Should print: PONG
# sudo systemctl enable redis - to enable redis server on startup

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60
INFLIGHT_DEDUPE_TTL_SECONDS=360

# Media limits
MAX_FILE_SIZE_MB=50
MEDIA_CACHE_TTL_SECONDS=86400

# App paths/logging
TEMP_DIR=./temp
LOG_LEVEL=info
LOG_DIR=./logs
